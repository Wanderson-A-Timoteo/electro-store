<div class="row justify-content-center mt-5 text-center">
  <div class="col-md-8">

    {{#if success}}
    <div class="alert alert-success alert-dismissible fade show text-start shadow-sm" role="alert">
      <i class="bi bi-check-circle-fill"></i> {{success}}
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {{/if}}

    {{#if error}}
    <div class="alert alert-danger alert-dismissible fade show text-start shadow-sm" role="alert">
      <i class="bi bi-exclamation-triangle-fill"></i> {{error}}
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
    {{/if}}

    <h1 class="display-4 fw-bold"><i class="bi bi-shop text-primary"></i> Bem-vindo à ElectroStore</h1>
    <p class="lead text-muted mt-3">O seu sistema de gerenciamento e vendas de eletrônicos.</p>
    <hr class="my-4">

    <p>Acesse o sistema para visualizar e gerenciar nossos produtos.</p>
  </div>
</div>
