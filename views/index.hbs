<div class="row mb-4 mt-3">
  <div class="col-md-12 text-center">
    <h1 class="display-5 fw-bold"><i class="bi bi-shop text-primary"></i> Acervo ElectroStore</h1>
    <p class="text-muted">Confira nossos produtos disponíveis.</p>
    <hr>
  </div>
</div>

{{#if success}}
<div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
  <i class="bi bi-check-circle-fill"></i> {{success}}
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
{{/if}}

{{#if error}}
<div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
  <i class="bi bi-exclamation-triangle-fill"></i> {{error}}
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
{{/if}}

<div class="row row-cols-1 row-cols-md-3 g-4">
  {{#each produtos}}
  <div class="col">
    <div class="card h-100 shadow-sm border-0">
      <div class="bg-light text-center py-4 rounded-top">
        <i class="bi bi-laptop text-secondary" style="font-size: 4rem;"></i>
      </div>

      <div class="card-body">
        <h5 class="card-title fw-bold">{{this.nome}}</h5>
        <p class="card-text text-muted small mb-3">{{this.descricao}}</p>
        <h4 class="text-success fw-bold">R$ {{this.preco}}</h4>

        <p class="mb-1"><small><strong>Estoque:</strong> {{this.quantidade}} unidades</small></p>
        <p class="mb-1"><small><strong>Categoria:</strong> {{this.Categoria.nome}}</small></p>

        <p class="mb-0"><small><strong>Status:</strong>
            {{#if (eq this.status 'ativo')}}
            <span class="badge bg-success">Ativo</span>
            {{else}}
            <span class="badge bg-danger">Inativo</span>
            {{/if}}
          </small></p>
      </div>

      {{#if ../isAdmin}}
      <div class="card-footer bg-white border-0 d-flex justify-content-between pb-3">
        <a href="/produto/editar/{{this.id}}" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-pencil"></i> Editar
        </a>

        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal"
          data-bs-target="#modalExcluir{{this.id}}">
          <i class="bi bi-trash"></i> Excluir
        </button>

        <div class="modal fade" id="modalExcluir{{this.id}}" tabindex="-1"
          aria-labelledby="modalExcluirLabel{{this.id}}" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title" id="modalExcluirLabel{{this.id}}"><i
                    class="bi bi-exclamation-triangle-fill"></i> Confirmar Exclusão</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                  aria-label="Fechar"></button>
              </div>
              <div class="modal-body text-start text-dark py-4">
                Tem a certeza que deseja excluir permanentemente o produto <strong
                  class="text-danger">{{this.nome}}</strong>? Esta ação não pode ser desfeita.
              </div>
              <div class="modal-footer border-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form action="/produto/excluir/{{this.id}}" method="POST" class="m-0 p-0">
                  <button type="submit" class="btn btn-danger">Sim, Excluir</button>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
      {{/if}}
    </div>
  </div>
  {{else}}
  
  <div class="col-12 d-flex justify-content-center w-100 mt-4">
    <div class="text-center p-5 shadow-sm rounded-4 bg-white border" style="max-width: 500px; width: 100%;">
      <i class="bi bi-inbox text-muted mb-3" style="font-size: 5rem; display: block;"></i>
      <h3 class="text-muted fw-bold">O acervo está vazio</h3>
      <p class="text-muted mb-4">Ainda não existem produtos cadastrados ou disponíveis para visualização no momento.</p>
  
      {{#if @root.isAdmin}}
      <a href="/produto/cadastrar" class="btn btn-primary mt-2 shadow-sm w-100 fw-bold">
        <i class="bi bi-plus-circle"></i> Cadastrar o Primeiro Produto
      </a>
      {{/if}}
    </div>
  </div>
  
  {{/each}}
  </div>
</div>
